# Local remote-category node example

COMPOSE_PROJECT_NAME=huihaokang-category-node
HUIHAOKANG_IMAGE_TAG=stable

# Worker identity shown in NAS /api/workers and control plane
NOON_WORKER_NODE_HOST=local-category-node
NOON_CATEGORY_WAREHOUSE_SYNC_MODE=enqueue_shared
NOON_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
NOON_BROWSER_CDP_ENDPOINT=http://host.docker.internal:9222
NOON_CATEGORY_WARMUP_URL=https://www.noon.com/saudi-en/search?q=foam%20roller

# Browser/runtime paths on the local crawler machine
NOON_HOST_DATA_DIR=./data
NOON_HOST_RUNTIME_DATA_DIR=./runtime_data
NOON_HOST_BROWSER_PROFILES_DIR=./browser_profiles
NOON_HOST_LOGS_DIR=./logs
NOON_HOST_SSH_DIR=./ssh

# NAS Postgres access
# docker-compose.category-node.yml will launch a dedicated `nas-db-tunnel`
# sidecar that maintains:
#   nas-db-tunnel:55432 -> NAS 127.0.0.1:55432
# The category worker only talks to that internal tunnel service.
NOON_OPS_DATABASE_URL=postgresql://noon:changeme@nas-db-tunnel:55432/noon_ops
NOON_PRODUCT_STORE_DATABASE_URL=postgresql://noon:changeme@nas-db-tunnel:55432/noon_stage
NOON_WAREHOUSE_DATABASE_URL=postgresql://noon:changeme@nas-db-tunnel:55432/noon_warehouse
# Shared sync tasks are consumed by NAS sync-worker, so the queued DB refs
# must use NAS-internal service names rather than the local SSH tunnel host.
NOON_SHARED_SYNC_TRIGGER_DB_REF=postgresql://noon:changeme@postgres:5432/noon_stage
NOON_SHARED_SYNC_WAREHOUSE_DB_REF=postgresql://noon:changeme@postgres:5432/noon_warehouse

# Minimal runtime artifact push back to NAS shared storage
NOON_CATEGORY_ARTIFACT_SYNC_MODE=ssh_push
NOON_REMOTE_ARTIFACT_SSH_HOST=192.168.100.20
NOON_REMOTE_ARTIFACT_SSH_PORT=22
NOON_REMOTE_ARTIFACT_SSH_USER=admin
# Identity file path is inside the container after NOON_HOST_SSH_DIR is mounted to /root/.ssh
NOON_REMOTE_ARTIFACT_SSH_IDENTITY_FILE=/root/.ssh/id_ed25519
NOON_REMOTE_CATEGORY_BATCH_ROOT=/volume1/docker/huihaokang-erp/shared/data/batch_scans
