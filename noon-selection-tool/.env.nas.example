# NAS stable environment example

# Compose identity
COMPOSE_PROJECT_NAME=huihaokang-stable
NOON_STABLE_NETWORK_NAME=huihaokang-stable-net

# Core paths
NOON_WAREHOUSE_DB=/app/data/analytics/warehouse.db
NOON_OPS_DB=/app/data/ops/ops.db
NOON_PRODUCT_STORE_DB=/app/data/product_store.db
NOON_OPS_DATABASE_URL=
NOON_WAREHOUSE_DATABASE_URL=
NOON_PRODUCT_STORE_DATABASE_URL=
NOON_BROWSER_PROFILE_ROOT=/app/browser_profiles
NOON_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
HUIHAOKANG_IMAGE_TAG=stable

# Host bind mounts
NOON_HOST_DATA_DIR=/volume1/docker/huihaokang-erp/shared/data
NOON_HOST_RUNTIME_DATA_DIR=/volume1/docker/huihaokang-erp/shared/runtime_data
NOON_HOST_BROWSER_PROFILES_DIR=/volume1/docker/huihaokang-erp/shared/browser_profiles
NOON_HOST_LOGS_DIR=/volume1/docker/huihaokang-erp/shared/logs
NOON_HOST_POSTGRES_DIR=/volume1/docker/huihaokang-erp/shared/postgres

# Postgres service
NOON_POSTGRES_DB=noon
NOON_POSTGRES_USER=noon
NOON_POSTGRES_PASSWORD=changeme

# Runtime behavior
NOON_SCHEDULER_RUNTIME=host
NOON_BROWSER_HEADLESS=true
NOON_BROWSER_CHANNEL=
NOON_MAX_CONCURRENT_TASKS=1
TASK_LEASE_TIMEOUT_SECONDS=3600
WORKER_POLL_SECONDS=10
SCHEDULER_POLL_SECONDS=15

# Proxy (optional)
PROXY_HOST=
PROXY_PORT=0
PROXY_USER=
PROXY_PASS=
PROXY_URL=

# Business settings
KSA_EXCHANGE_RATE=1.90
SHIPPING_RATE_CBM=2000
SHIPPING_RATE_CBM_PEACETIME=950
DEFAULT_AD_RATE=0.05
DEFAULT_RETURN_RATE=0.03

# Scraper settings
MIN_DELAY=2.0
MAX_DELAY=5.0
MAX_RETRIES=3
CONCURRENT_BROWSERS=2
PRODUCTS_PER_KEYWORD=30

# Optional scheduler defaults
DEFAULT_KEYWORD_MONITOR_CONFIG=config/keyword_monitor_pet_sports_batch.json

# Cloudflare Tunnel
TUNNEL_TOKEN=
