# Noon 选品系统 — 环境配置
# 复制此文件为 .env 并填入实际值

# ── 代理配置（可选，推荐用于 Amazon/Temu） ──
PROXY_HOST=
PROXY_PORT=0
PROXY_USER=
PROXY_PASS=

# ── SHEIN API（Phase 1 预留，充值后即可使用） ──
SHEIN_API_KEY=
SHEIN_API_PROVIDER=brightdata

# ── 业务参数 ──
KSA_EXCHANGE_RATE=1.90
SHIPPING_RATE_CBM=2000
SHIPPING_RATE_CBM_PEACETIME=950
DEFAULT_AD_RATE=0.05
DEFAULT_RETURN_RATE=0.03

# ── 爬虫参数 ──
MIN_DELAY=2.0
MAX_DELAY=5.0
MAX_RETRIES=3
CONCURRENT_BROWSERS=3
PRODUCTS_PER_KEYWORD=30

# ── 监控模块配置（阶段1.5） ──
MONITOR_KEYWORD_COUNT=200
MONITOR_PRODUCT_COUNT=500
MONITOR_INTERVAL_SECONDS_MIN=5
MONITOR_INTERVAL_SECONDS_MAX=10
MONITOR_SESSIONS_PER_DAY=4

# Database backends (Phase 1)
# Default behavior remains SQLite via local file paths.
# To enable Postgres for the ops control plane, set NOON_OPS_DATABASE_URL.
# Example: postgresql://user:pass@localhost:5432/noon_ops
NOON_OPS_DB=
NOON_OPS_DATABASE_URL=
NOON_WAREHOUSE_DB=
NOON_WAREHOUSE_DATABASE_URL=
NOON_PRODUCT_STORE_DB=
NOON_PRODUCT_STORE_DATABASE_URL=
