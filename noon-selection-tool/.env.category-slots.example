# Remote category multi-slot deployment settings.
# Copy to .env.category-slots and adjust per device.

# v2rayN / Xray runtime
NOON_V2RAYN_DB_PATH=D:\v2rayN-windows-64\guiConfigs\guiNDB.db
NOON_V2RAYN_XRAY_PATH=D:\v2rayN-windows-64\bin\xray\xray.exe

# Host Chrome slot profiles
NOON_REMOTE_CATEGORY_SLOT_PROFILE_ROOT=D:\tmp\noon-browser-slots

# NAS control-plane workers API
NOON_REMOTE_CATEGORY_WORKERS_API_URL=http://192.168.1.3:8865/api/workers

# Docker compose project name for this device's multi-slot runtime
NOON_REMOTE_CATEGORY_SLOT_COMPOSE_PROJECT=huihaokang-category-slots

# Slot A selector: choose one.
# Prefer remarks for cross-device reuse; IndexId can change between machines.
SLOT_A_PROFILE_REMARKS=рҹҮӯрҹҮ° 00001.йҰҷжёҜ-iepl-NetflixдёЁTVBдёЁDisney+дёЁOpenAI
# SLOT_A_PROFILE_INDEX_ID=
SLOT_A_SOCKS_PORT=11081
SLOT_A_CDP_PORT=9224

# Slot B selector: choose one.
SLOT_B_PROFILE_REMARKS=00067.йҳҝиҒ”й…Ӣ-iepl
# SLOT_B_PROFILE_INDEX_ID=
SLOT_B_SOCKS_PORT=11082
SLOT_B_CDP_PORT=9225
