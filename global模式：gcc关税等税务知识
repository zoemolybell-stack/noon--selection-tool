## 七、利润测算插件中的关税计算模块设计建议

### 7.1 关税计算函数伪代码

```python
def calculate_customs_cost(cif_value_sar, hs_code_chapter, destination="KSA"):
    """
    计算进口至沙特的关税和清关总费用
    cif_value_sar: 商品CIF价值（SAR）
    hs_code_chapter: HS编码前2位（章节号）
    """
    
    # 第一步：确定关税税率
    duty_rate = get_duty_rate(hs_code_chapter)  # 默认5%，特殊品类查表
    
    # 第二步：计算关税
    customs_duty = cif_value_sar * duty_rate
    
    # 第三步：计算清关服务费（2024年10月新规）
    service_fee = max(15, min(500, cif_value_sar * 0.0015))
    
    # 第四步：计算进口VAT
    if destination == "KSA":
        import_vat = (cif_value_sar + customs_duty) * 0.15
    elif destination == "UAE":
        import_vat = (cif_value_sar + customs_duty) * 0.05
    
    # 第五步：总税费
    total_tax = customs_duty + service_fee + import_vat
    effective_tax_rate = total_tax / cif_value_sar
    
    return {
        "customs_duty": customs_duty,
        "service_fee": service_fee, 
        "import_vat": import_vat,
        "total_tax": total_tax,
        "effective_tax_rate": effective_tax_rate
    }

def get_duty_rate(hs_chapter):
    """根据HS编码章节返回关税税率"""
    high_duty = {94: 0.15}  # 家具部分15%
    medium_duty = {}  # 12%品类需按具体HS Code查表
    
    if hs_chapter in high_duty:
        return high_duty[hs_chapter]  # 注意：家具不是全部15%，需细分
    
    return 0.05  # 绝大多数Noon卖家商品适用5%标准税率
```

### 7.2 跨境定价模拟函数伪代码

```python
def simulate_global_pricing(uae_price_aed, duty_rate=0.05, usd_aed=3.67, usd_sar=3.75):
    """
    模拟Noon Global模式下UAE→KSA的自动定价
    """
    # 剥离UAE VAT
    uae_ex_vat = uae_price_aed / 1.05
    
    # 转为USD中转
    usd_price = uae_ex_vat / usd_aed
    
    # 转为SAR
    sar_ex_vat = usd_price * usd_sar
    
    # 加入关税
    customs = sar_ex_vat * duty_rate
    
    # 加入清关杂费（估算）
    clearance_fee = max(15, sar_ex_vat * 0.0015)
    
    # 加入KSA VAT
    sar_before_vat = sar_ex_vat + customs + clearance_fee
    ksa_final_price = sar_before_vat * 1.15
    
    return {
        "uae_price_aed": uae_price_aed,
        "uae_ex_vat": uae_ex_vat,
        "usd_transit": usd_price,
        "sar_ex_vat": sar_ex_vat,
        "customs_duty": customs,
        "clearance_fee": clearance_fee,
        "ksa_vat": sar_before_vat * 0.15,
        "ksa_final_price": round(ksa_final_price, 2),
        "price_markup_pct": round((ksa_final_price / (uae_price_aed / usd_aed * usd_sar) - 1) * 100, 1)
    }
```

### 7.3 跨境退货沉没成本计算

```python
def calculate_global_return_sunk_cost(cif_value, duty_rate=0.05, destination="KSA"):
    """
    计算Global模式退货时不可收回的沉没成本
    """
    customs_duty = cif_value * duty_rate  # 不可收回
    
    if destination == "KSA":
        import_vat = (cif_value + customs_duty) * 0.15  # 不可收回
    else:
        import_vat = (cif_value + customs_duty) * 0.05
    
    # 跨境双程运输费（估算）
    cross_border_shipping = cif_value * 0.10  # 约为货值10%的运输成本估算
    
    total_sunk_cost = customs_duty + import_vat + cross_border_shipping
    
    return {
        "customs_duty_lost": customs_duty,
        "import_vat_lost": import_vat,
        "shipping_lost": cross_border_shipping,
        "total_sunk_cost": total_sunk_cost,
        "sunk_cost_pct_of_value": round(total_sunk_cost / cif_value * 100, 1)
    }
```

